# Optional: Pfade fuer Linux-Serverbetrieb
# SECURITY_NEWS_CONFIG=/opt/security-news/config.json
# SECURITY_NEWS_DB_PATH=/var/lib/security-news/security_news.sqlite
# SECURITY_NEWS_SITE_PATH=/var/www/security-news/index.html

# Optional: Python-Binary, falls python3 nicht im PATH liegt
# PYTHON_BIN=/usr/bin/python3

# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=123456789

# E-Mail / SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=user@example.com
# SMTP_PASSWORD=app-password
# SMTP_FROM=security-news@example.com
# SMTP_TO=admin@example.com

# Optional fuer bessere NVD-Rate-Limits
# NVD_API_KEY=your-nvd-api-key
